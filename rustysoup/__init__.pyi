    ) -> None: ...
    @classmethod
    def detwingle(cls, in_bytes: bytes, main_encoding: str = "utf8", embedded_encoding: str = "windows-1252") -> bytes: ...

class HTMLParserTreeBuilder: ...
class TreeBuilder: ...
builder_registry: Any

